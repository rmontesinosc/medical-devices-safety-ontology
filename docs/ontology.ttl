###  http://example.org/medical-devices-ontology#FSCA_001
:FSCA_001 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ;
          :hasFSCAStatus :FS_Open ;
          :hasFSCAType :FT_SafetyAlert ;
          :hasActionDate "2024-02-01"^^xsd:date ;
          :hasCountriesAffected "EU-wide" ;
          :hasDevicesAffected 850 ;
          :hasEUDAMEDFSCARef "EU-FSCA-2024-000001" ;
          :hasFSCADescription "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          :hasFSCAID "FSCA-001" ;
          :hasScope "All HeartMate 3 LVAD units implanted since 2020" ;
          rdfs:comment "A field safety corrective action from the dataset." ;
          rdfs:label "FSCA-001" .


###  http://example.org/medical-devices-ontology#FSCA_002
:FSCA_002 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ;
          :hasFSCAStatus :FS_Closed ;
          :hasFSCAType :FT_Recall ;
          :hasActionDate "2024-02-28"^^xsd:date ;
          :hasClosureDate "2024-05-31"^^xsd:date ;
          :hasCountriesAffected "EU-wide + UK" ;
          :hasDevicesAffected 1240 ;
          :hasEUDAMEDFSCARef "EU-FSCA-2024-000002" ;
          :hasFSCADescription "Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced." ;
          :hasFSCAID "FSCA-002" ;
          :hasScope "Micra AV lots manufactured between 2022-09 and 2023-03" ;
          rdfs:comment "A field safety corrective action from the dataset." ;
          rdfs:label "FSCA-002" .


###  http://example.org/medical-devices-ontology#FSCA_003
:FSCA_003 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ;
          :hasFSCAStatus :FS_Closed ;
          :hasFSCAType :FT_InSituCorrection ;
          :hasActionDate "2024-03-15"^^xsd:date ;
          :hasClosureDate "2024-06-30"^^xsd:date ;
          :hasCountriesAffected "EU-wide" ;
          :hasDevicesAffected 320 ;
          :hasEUDAMEDFSCARef "EU-FSCA-2024-000003" ;
          :hasFSCADescription "Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres." ;
          :hasFSCAID "FSCA-003" ;
          :hasScope "Portico THV sizes 23mm and 25mm from lots before 2023-11" ;
          rdfs:comment "A field safety corrective action from the dataset." ;
          rdfs:label "FSCA-003" .


###  http://example.org/medical-devices-ontology#FSCA_004
:FSCA_004 rdf:type owl:NamedIndividual ,
                   :CorrectiveAction ;
          :hasFSCAStatus :FS_Open ;
          :hasFSCAType :FT_SafetyAlert ;
          :hasActionDate "2024-04-10"^^xsd:date ;
          :hasCountriesAffected "EU-wide" ;
          :hasDevicesAffected 2100 ;
          :hasEUDAMEDFSCARef "EU-FSCA-2024-000004" ;
          :hasFSCADescription "Safety communication to implanting cardiologists regarding optimal fixation technique for ACUITY X4 lead. Enhanced fluoroscopy verification protocol at implantation." ;
