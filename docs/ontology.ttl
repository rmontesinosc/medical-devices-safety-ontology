<https://rmontesinosc.github.io/medical-devices-safety-ontology/> rdf:type owl:Ontology ;
                                                                   owl:versionIRI <https://rmontesinosc.github.io/medical-devices-safety-ontology/1.0/> ;
                                                                   <http://purl.org/dc/terms/creator> "Rafael Montesinos Cano" ;
                                                                   <http://purl.org/dc/terms/description> "An ontology for modelling medical devices, safety incidents, risk classifications, manufacturers, regulatory frameworks and corrective actions in the medical device domain."@en ;
                                                                   <http://purl.org/dc/terms/issued> "2026-04-27"^^xsd:date ;
                                                                   <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                   <http://purl.org/dc/terms/modified> "2026-04-27"^^xsd:date ;
                                                                   <http://purl.org/dc/terms/provenance> "The ontology was developed as part of an academic practice on ontology engineering, documentation and publication using Protégé, WIDOCO, OOPS!, FOOPS! and GitHub Pages."@en ;
                                                                   <http://purl.org/dc/terms/title> "Medical Devices Safety Ontology"@en ;
                                                                   <http://purl.org/vocab/vann/preferredNamespacePrefix> "mdso" ;
                                                                   <http://purl.org/vocab/vann/preferredNamespaceUri> "https://rmontesinosc.github.io/medical-devices-safety-ontology#" ;
                                                                   rdfs:comment "Ontology for representing medical devices, incidents, risks, manufacturers, regulatory frameworks and corrective actions."@en ;
                                                                   rdfs:label "Medical Devices Safety Ontology"@en ;
                                                                   owl:versionInfo "1.0" ;
                                                                   <http://www.w3.org/ns/prov#generatedAtTime> "2026-04-27T00:00:00Z"^^xsd:dateTime ;
                                                                   <http://www.w3.org/ns/prov#wasAttributedTo> <https://rmontesinosc.github.io/medical-devices-safety-ontology#RafaelMontesinosCano> ;
                                                                   <http://www.w3.org/ns/prov#wasGeneratedBy> <https://rmontesinosc.github.io/medical-devices-safety-ontology#OntologyDevelopmentActivity> .

