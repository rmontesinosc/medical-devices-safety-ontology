@prefix : <http://example.org/medical-devices-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/medical-devices-ontology#> .

<http://example.org/medical-devices-ontology> rdf:type owl:Ontology ;
                                               <http://purl.org/dc/terms/creator> "Rafael Montesinos Cano" ;
                                               <http://purl.org/dc/terms/description> "An ontology for modelling medical devices, safety incidents, risk classifications, manufacturers, regulatory frameworks and corrective actions in the medical device domain."@en ;
                                               <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                               <http://purl.org/dc/terms/title> "Medical Devices Safety Ontology"@en ;
                                               rdfs:comment "Ontology for representing medical devices, incidents, risks, manufacturers, regulatory frameworks and corrective actions."@en ;
                                               rdfs:label "Medical Devices Safety Ontology"@en ;
                                               owl:versionInfo "1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/medical-devices-ontology#affectsDeviceType
:affectsDeviceType rdf:type owl:ObjectProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :DeviceType ;
                   rdfs:label "Links a risk to a type of device affected by it"@en ,
                              "affects device type"@en .


###  http://example.org/medical-devices-ontology#hasCorrectiveAction
:hasCorrectiveAction rdf:type owl:ObjectProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range :CorrectiveAction ;
                     rdfs:comment "Links an incident to the corrective action taken in response"@en ;
                     rdfs:label "has corrective action"@en .


###  http://example.org/medical-devices-ontology#hasFSCAStatus
:hasFSCAStatus rdf:type owl:ObjectProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range :FSCAStatus ;
               rdfs:comment "Links a corrective action to its FSCA status"@en ;
               rdfs:label "has FSCA status"@en .


###  http://example.org/medical-devices-ontology#hasFSCAType
:hasFSCAType rdf:type owl:ObjectProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range :FSCAType ;
             rdfs:comment "Links a corrective action to its FSCA type"@en ;
             rdfs:label "has FSCA type"@en .


###  http://example.org/medical-devices-ontology#hasIncident
:hasIncident rdf:type owl:ObjectProperty ;
             rdfs:domain :MedicalDevice ;
             rdfs:range :Incident ;
             rdfs:comment "Links a medical device to an incident associated with it"@en ;
             rdfs:label "has incident"@en .


###  http://example.org/medical-devices-ontology#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 rdfs:domain :MedicalDevice ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Links a medical device to its manufacturer"@en ;
                 rdfs:label "has manufacturer"@en .


###  http://example.org/medical-devices-ontology#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :MedicalDevice ;
              rdfs:range :RiskClass ;
              rdfs:comment "Links a medical device to its regulatory risk class"@en ;
              rdfs:label "has risk class"@en .


###  http://example.org/medical-devices-ontology#relatedRisk
:relatedRisk rdf:type owl:ObjectProperty ;
             rdfs:domain :Incident ;
             rdfs:range :Risk ;
             rdfs:comment "Links an incident to a risk"@en ;
             rdfs:label "related risk"@en .


###  http://example.org/medical-devices-ontology#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Links an incident to the reporting manufacturer"@en ;
            rdfs:label "reported by"@en .


###  http://example.org/medical-devices-ontology#subjectToCorrectiveAction
:subjectToCorrectiveAction rdf:type owl:ObjectProperty ;
                           rdfs:domain :MedicalDevice ;
                           rdfs:range :CorrectiveAction ;
                           rdfs:label "Links a medical device to a corrective action associated through an incident"@en ,
                                      "subject to corrective action"@en .


###  http://example.org/medical-devices-ontology#underRegulatoryFramework
:underRegulatoryFramework rdf:type owl:ObjectProperty ;
                          rdfs:domain :MedicalDevice ;
                          rdfs:range :RegulatoryFramework ;
                          rdfs:comment "Links a medical device to the regulatory framework that applies to it"@en ;
                          rdfs:label "under regulatory framework"@en .


#################################################################
#    Data properties
#################################################################

###  http://example.org/medical-devices-ontology#correctiveActionTaken
:correctiveActionTaken rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:boolean ;
                       rdfs:comment "Indicates whether a corrective action was taken for the incident"@en ;
                       rdfs:label "corrective action taken"@en .


###  http://example.org/medical-devices-ontology#hasActionDate
:hasActionDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range xsd:date ;
               rdfs:comment "Stores the date on which a corrective action started"@en ;
               rdfs:label "has action date"@en .


###  http://example.org/medical-devices-ontology#hasAffectedDeviceTypeText
:hasAffectedDeviceTypeText rdf:type owl:DatatypeProperty ;
                           rdfs:domain :Risk ;
                           rdfs:range xsd:string ;
                           rdfs:comment "Stores the textual value of the affected device type"@en ;
                           rdfs:label "has affected device type text"@en .


###  http://example.org/medical-devices-ontology#hasAuthorizationNumber
:hasAuthorizationNumber rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Manufacturer ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Stores the regulatory authorization number of a manufacturer"@en ;
                        rdfs:label "has authorization number"@en .


###  http://example.org/medical-devices-ontology#hasClosureDate
:hasClosureDate rdf:type owl:DatatypeProperty ;
                rdfs:domain :CorrectiveAction ;
                rdfs:range xsd:date ;
                rdfs:comment "Stores the date on which a corrective action was closed"@en ;
                rdfs:label "has closure date"@en .


###  http://example.org/medical-devices-ontology#hasCompetentAuthority
:hasCompetentAuthority rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Manufacturer ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Stores the competent authority associated with a manufacturer"@en ;
                       rdfs:label "has competent authority"@en .


###  http://example.org/medical-devices-ontology#hasContactEmail
:hasContactEmail rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Manufacturer ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Stores the contact email of a manufacturer"@en ;
                 rdfs:label "has contact email"@en .


###  http://example.org/medical-devices-ontology#hasCountriesAffected
:hasCountriesAffected rdf:type owl:DatatypeProperty ;
                      rdfs:domain :CorrectiveAction ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Stores the countries affected by a corrective action"@en ;
                      rdfs:label "has countries affected"@en .


###  http://example.org/medical-devices-ontology#hasCountry
:hasCountry rdf:type owl:DatatypeProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            rdfs:comment "Stores the country where a manufacturer is located"@en ;
            rdfs:label "has country"@en .


###  http://example.org/medical-devices-ontology#hasCountryReported
:hasCountryReported rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Stores the country where the incident was reported"@en ;
                    rdfs:label "has country reported"@en .


###  http://example.org/medical-devices-ontology#hasDetectionDate
:hasDetectionDate rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Incident ;
                  rdfs:range xsd:date ;
                  rdfs:comment "Stores the date on which an incident was detected."@en ;
                  rdfs:label "has detection date"@en .


###  http://example.org/medical-devices-ontology#hasDeviceID
:hasDeviceID rdf:type owl:DatatypeProperty ;
             rdfs:domain :MedicalDevice ;
             rdfs:range xsd:string ;
             rdfs:comment "Stores the identifier of a manufacturer"@en ;
             rdfs:label "has device ID"@en .


###  http://example.org/medical-devices-ontology#hasDeviceName
:hasDeviceName rdf:type owl:DatatypeProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range xsd:string ;
               rdfs:comment "Stores the commercial name of a medical device"@en ;
               rdfs:label "has device name"@en .


###  http://example.org/medical-devices-ontology#hasDeviceTypeText
:hasDeviceTypeText rdf:type owl:DatatypeProperty ;
                   rdfs:domain :MedicalDevice ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Stores the textual value of the device type"@en ;
                   rdfs:label "has device type text"@en .


###  http://example.org/medical-devices-ontology#hasDevicesAffected
:hasDevicesAffected rdf:type owl:DatatypeProperty ;
                    rdfs:domain :CorrectiveAction ;
                    rdfs:range xsd:int ;
                    rdfs:comment "Stores the number of devices affected by a corrective action"@en ;
                    rdfs:label "has devices affected"@en .


###  http://example.org/medical-devices-ontology#hasEUDAMEDFSCARef
:hasEUDAMEDFSCARef rdf:type owl:DatatypeProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Stores the EUDAMED reference of a corrective action"@en ;
                   rdfs:label "has EUDAMED FSCA reference"@en .


###  http://example.org/medical-devices-ontology#hasEUDAMEDIncidentRef
:hasEUDAMEDIncidentRef rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Stores the EUDAMED reference of an incident"@en ;
                       rdfs:label "has EUDAMED incident reference"@en .


###  http://example.org/medical-devices-ontology#hasEUDAMEDSRN
:hasEUDAMEDSRN rdf:type owl:DatatypeProperty ;
               rdfs:domain :Manufacturer ;
               rdfs:range xsd:string ;
               rdfs:comment "Stores the EUDAMED SRN of a manufacturer."@en ;
               rdfs:label "has EUDAMED SRN"@en .


###  http://example.org/medical-devices-ontology#hasEventDate
:hasEventDate rdf:type owl:DatatypeProperty ;
              rdfs:domain :Incident ;
              rdfs:range xsd:date ;
              rdfs:comment "Stores the date on which the incident event occurred."@en ;
              rdfs:label "has event date"@en .


###  http://example.org/medical-devices-ontology#hasFSCADescription
:hasFSCADescription rdf:type owl:DatatypeProperty ;
                    rdfs:domain :CorrectiveAction ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Stores the description of a corrective action"@en ;
                    rdfs:label "has FSCA description"@en .


###  http://example.org/medical-devices-ontology#hasFSCAID
:hasFSCAID rdf:type owl:DatatypeProperty ;
           rdfs:domain :CorrectiveAction ;
           rdfs:range xsd:string ;
           rdfs:comment "Stores the identifier of a field safety corrective action"@en ;
           rdfs:label "has FSCA ID"@en .


###  http://example.org/medical-devices-ontology#hasIMDRFCode
:hasIMDRFCode rdf:type owl:DatatypeProperty ;
              rdfs:domain :Risk ;
              rdfs:range xsd:string ;
              rdfs:comment "Stores the IMDRF code assigned to a risk"@en ;
              rdfs:label "has IMDRF code"@en .


###  http://example.org/medical-devices-ontology#hasIncidentDescription
:hasIncidentDescription rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Incident ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Stores the description of an incident"@en ;
                        rdfs:label "has incident description"@en .


###  http://example.org/medical-devices-ontology#hasIncidentID
:hasIncidentID rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:string ;
               rdfs:comment "Stores the identifier of an incident."@en ;
               rdfs:label "has incident ID"@en .


###  http://example.org/medical-devices-ontology#hasIncidentTypeText
:hasIncidentTypeText rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Stores the textual value of the incident type"@en ;
                     rdfs:label "has incident type text" .


###  http://example.org/medical-devices-ontology#hasIntendedPurpose
:hasIntendedPurpose rdf:type owl:DatatypeProperty ;
                    rdfs:domain :MedicalDevice ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Stores the intended purpose of a medical device"@en ;
                    rdfs:label "has intended purpose"@en .


###  http://example.org/medical-devices-ontology#hasManufacturerID
:hasManufacturerID rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Manufacturer ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Stores the identifier of a manufacturer."@en ;
                   rdfs:label "has manufacturer ID"@en .


###  http://example.org/medical-devices-ontology#hasManufacturerName
:hasManufacturerName rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Stores the name of a manufacturer"@en ;
                     rdfs:label "has manufacturer name"@en .


###  http://example.org/medical-devices-ontology#hasOutcome
:hasOutcome rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:label "Stores the outcome of an incident"@en ,
                       "has outcome"@en .


###  http://example.org/medical-devices-ontology#hasPatientAge
:hasPatientAge rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:int ;
               rdfs:comment "Stores the age of the patient associated with an incident"@en ;
               rdfs:label "has patient age"@en .


###  http://example.org/medical-devices-ontology#hasPatientSex
:hasPatientSex rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:string ;
               rdfs:comment "Stores the sex of the patient associated with an incident"@en ;
               rdfs:label "has patient sex"@en .


###  http://example.org/medical-devices-ontology#hasProbabilityText
:hasProbabilityText rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Stores the textual value of the probability level"@en ;
                    rdfs:label "has probability text" .


###  http://example.org/medical-devices-ontology#hasReportDate
:hasReportDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "Stores the date on which an incident was reported."@en ;
               rdfs:label "has report date"@en .


###  http://example.org/medical-devices-ontology#hasRiskCategoryText
:hasRiskCategoryText rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Risk ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Stores the textual value of the risk category"@en ;
                     rdfs:label "has risk category text"@en .


###  http://example.org/medical-devices-ontology#hasRiskDescription
:hasRiskDescription rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Stores the description of a risk"@en ;
                    rdfs:label "has risk description"@en .


###  http://example.org/medical-devices-ontology#hasRiskID
:hasRiskID rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "Stores the identifier of a risk"@en ;
           rdfs:label "has risk ID"@en .


###  http://example.org/medical-devices-ontology#hasRiskName
:hasRiskName rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "Stores the name of a risk"@en ;
             rdfs:label "has risk name"@en .


###  http://example.org/medical-devices-ontology#hasRiskTypeText
:hasRiskTypeText rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Stores the textual value of the risk type"@en ;
                 rdfs:label "has risk type text"@en .


###  http://example.org/medical-devices-ontology#hasScope
:hasScope rdf:type owl:DatatypeProperty ;
          rdfs:domain :CorrectiveAction ;
          rdfs:range xsd:string ;
          rdfs:comment "Stores the scope of a corrective action"@en ;
          rdfs:label "has scope"@en .


###  http://example.org/medical-devices-ontology#hasSeverityText
:hasSeverityText rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Stores the textual value of the severity level"@en ;
                 rdfs:label "has severity text"@en .


###  http://example.org/medical-devices-ontology#hasUDIDI
:hasUDIDI rdf:type owl:DatatypeProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:string ;
          rdfs:comment "Stores the UDI-DI of a medical device"@en ;
          rdfs:label "has UDI-DI"@en .


###  http://example.org/medical-devices-ontology#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Indicates whether the device is active"@en ;
          rdfs:label "is active"@en .


###  http://example.org/medical-devices-ontology#isIVD
:isIVD rdf:type owl:DatatypeProperty ;
       rdfs:domain :MedicalDevice ;
       rdfs:range xsd:boolean ;
       rdfs:label "Indicates whether the device is an in vitro diagnostic device"@en ,
                  "is IVD"@en .


###  http://example.org/medical-devices-ontology#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Indicates whether the device is implantabl"@en ;
               rdfs:label "is implantable"@en .


###  http://example.org/medical-devices-ontology#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :MedicalDevice ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the device is reusable."@en ;
            rdfs:label "is reusable"@en .


#################################################################
#    Classes
#################################################################

###  http://example.org/medical-devices-ontology#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDevice ;
              rdfs:comment "A medical device that depends on a source of energy for its operation"@en ;
              rdfs:label "Active Device"@en .


###  http://example.org/medical-devices-ontology#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:comment "An action taken in response to an incident"@en ;
                  rdfs:label "Corrective Action"@en .


###  http://example.org/medical-devices-ontology#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:comment "A category describing the type of a medical device"@en ;
            rdfs:label "Device Type"@en .


###  http://example.org/medical-devices-ontology#FSCAStatus
:FSCAStatus rdf:type owl:Class ;
            rdfs:comment "The status of a corrective action"@en ;
            rdfs:label "FSCA Status"@en .


###  http://example.org/medical-devices-ontology#FSCAType
:FSCAType rdf:type owl:Class ;
          rdfs:comment "A type of field safety corrective action"@en ;
          rdfs:label "FSCA Type"@en .


###  http://example.org/medical-devices-ontology#HighRiskDevice
:HighRiskDevice rdf:type owl:Class ;
                rdfs:subClassOf :MedicalDevice ;
                rdfs:comment "A medical device considered high risk according to regulatory classification"@en ;
                rdfs:label "High-Risk Device"@en .


###  http://example.org/medical-devices-ontology#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :MedicalDevice ;
                   rdfs:comment "medical device intended to be implanted in the human body"@en ;
                   rdfs:label "Implantable Device"@en .


###  http://example.org/medical-devices-ontology#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :FSCAType ;
                  rdfs:comment "A corrective action performed directly on the affected device or system"@en ;
                  rdfs:label "In Situ Correction"@en .


###  http://example.org/medical-devices-ontology#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :MedicalDevice ;
                         rdfs:comment "A medical device used for in vitro diagnostic purposes"@en ;
                         rdfs:label "In Vitro Diagnostic Device"@en .


###  http://example.org/medical-devices-ontology#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :relatedRisk ;
                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Risk
                          ] ;
          rdfs:comment "A reported incident involving in a medical device"@en ;
          rdfs:label "Incident"@en .


###  http://example.org/medical-devices-ontology#IncidentType
:IncidentType rdf:type owl:Class ;
              rdfs:comment "A category describing the type of an incident"@en ;
              rdfs:label "Incident Type"@en .


###  http://example.org/medical-devices-ontology#ManagedIncident
:ManagedIncident rdf:type owl:Class ;
                 rdfs:comment "An incident that has an associated corrective action"@en ;
                 rdfs:label "Managed Incident"@en .


###  http://example.org/medical-devices-ontology#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:comment "An organization responsible for manufacturing a medical device"@en ;
              rdfs:label "Manufacturer"@en ;
              rdfs:seeAlso "http://xmlns.com/foaf/0.1/Organization"@en .


###  http://example.org/medical-devices-ontology#MedicalDevice
:MedicalDevice rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasManufacturer ;
                                 owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :Manufacturer
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasDeviceID ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onDataRange xsd:string
                               ] ;
               rdfs:comment "A medical device represented in the ontology"@en ;
               rdfs:label "Medical Device"@en ;
               rdfs:seeAlso "https://schema.org/MedicalDevice"@en .


###  http://example.org/medical-devices-ontology#OpenCorrectiveAction
:OpenCorrectiveAction rdf:type owl:Class ;
                      rdfs:comment "A corrective action whose status is open"@en ;
                      rdfs:label "Open Corrective Action"@en .


###  http://example.org/medical-devices-ontology#ProbabilityLevel
:ProbabilityLevel rdf:type owl:Class ;
                  rdfs:comment "A probability level associated with a risk"@en ;
                  rdfs:label "Probability Level"@en .


###  http://example.org/medical-devices-ontology#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :FSCAType ;
        rdfs:comment "A corrective action involving the recall of affected products"@en ;
        rdfs:label "Recall"@en .


###  http://example.org/medical-devices-ontology#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     rdfs:comment "A European regulatory framework applicable to a medical device"@en ;
                     rdfs:label "Regulatory Framework"@en .


###  http://example.org/medical-devices-ontology#ReusableDevice
:ReusableDevice rdf:type owl:Class ;
                rdfs:subClassOf :MedicalDevice ;
                rdfs:comment "A medical device intended for repeated use"@en ;
                rdfs:label "Reusable Device"@en .


###  http://example.org/medical-devices-ontology#Risk
:Risk rdf:type owl:Class ;
      rdfs:comment "A risk associated with a medical device"@en ;
      rdfs:label "Risk"@en .


###  http://example.org/medical-devices-ontology#RiskCategory
:RiskCategory rdf:type owl:Class ;
              rdfs:comment "A conceptual category used to classify risks"@en ;
              rdfs:label "Risk Category"@en .


###  http://example.org/medical-devices-ontology#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "A regulatory risk class assigned to a medical device"@en ;
           rdfs:label "Risk Class"@en .


###  http://example.org/medical-devices-ontology#RiskType
:RiskType rdf:type owl:Class ;
          rdfs:comment "A conceptual type used to classify risks"@en ;
          rdfs:label "Risk Type"@en .


###  http://example.org/medical-devices-ontology#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :FSCAType ;
             rdfs:comment "A corrective action consisting of a safety alert"@en ;
             rdfs:label "Safety Alert"@en .


###  http://example.org/medical-devices-ontology#Severity
:Severity rdf:type owl:Class ;
          rdfs:comment "A severity level associated with a risk"@en ;
          rdfs:label "Severity"@en .


###  http://example.org/medical-devices-ontology#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :FSCAType ;
            rdfs:comment "A corrective action consisting of a notice or communication to users"@en ;
            rdfs:label "User Notice"@en .


