#################################################################
#    Classes
#################################################################

###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ActiveDevice
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ActiveDevice> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> ;
                                                                               owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#HighRiskDevice> ,
                                                                                                <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ImplantableDevice> ,
                                                                                                <https://rmontesinosc.github.io/medical-devices-safety-ontology/#InVitroDiagnosticDevice> ,
                                                                                                <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice> ;
                                                                               rdfs:comment "A medical device that depends on a source of energy for its operation"@en ;
                                                                               rdfs:label "Active Device"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassC
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassC> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass> ;
                                                                         owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassD> ,
                                                                                          <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIII> ,
                                                                                          <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIa> ,
                                                                                          <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIb> ;
                                                                         rdfs:comment "Risk class C for medical devices."@en ;
                                                                         rdfs:label "Class C"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassD
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassD> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass> ;
                                                                         owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIII> ,
                                                                                          <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIa> ,
                                                                                          <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIb> ;
                                                                         rdfs:comment "Risk class D for medical devices."@en ;
                                                                         rdfs:label "Class D"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIII
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIII> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass> ;
                                                                           owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIa> ,
                                                                                            <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIb> ;
                                                                           rdfs:comment "Risk class III for medical devices."@en ;
                                                                           rdfs:label "Class III"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIa
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIa> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass> ;
                                                                           owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIb> ;
                                                                           rdfs:comment "Risk class IIa for medical devices."@en ;
                                                                           rdfs:label "Class IIa"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIb
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ClassIIb> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass> ;
                                                                           rdfs:comment "Risk class IIb for medical devices."@en ;
                                                                           rdfs:label "Class IIb"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#Closed
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#Closed> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAStatus> ;
                                                                         owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Open> ;
                                                                         rdfs:comment "Status indicating that a field safety corrective action is closed."@en ;
                                                                         rdfs:label "Closed"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction> rdf:type owl:Class ;
                                                                                   rdfs:comment "An action taken in response to an incident"@en ;
                                                                                   rdfs:label "Corrective Action"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#DeviceType
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#DeviceType> rdf:type owl:Class ;
                                                                             rdfs:comment "A category describing the type of a medical device"@en ;
                                                                             rdfs:label "Device Type"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAStatus
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAStatus> rdf:type owl:Class ;
                                                                             rdfs:comment "The status of a corrective action"@en ;
                                                                             rdfs:label "FSCA Status"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType> rdf:type owl:Class ;
                                                                           rdfs:comment "A type of field safety corrective action"@en ;
                                                                           rdfs:label "FSCA Type"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#HighRiskDevice
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#HighRiskDevice> rdf:type owl:Class ;
                                                                                 rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> ;
                                                                                 owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ImplantableDevice> ,
                                                                                                  <https://rmontesinosc.github.io/medical-devices-safety-ontology/#InVitroDiagnosticDevice> ,
                                                                                                  <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice> ;
                                                                                 rdfs:comment "A medical device considered high risk according to regulatory classification"@en ;
                                                                                 rdfs:label "High-Risk Device"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#IVDR
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#IVDR> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#RegulatoryFramework> ;
                                                                       owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MDR> ;
                                                                       rdfs:comment "In Vitro Diagnostic Medical Devices Regulation."@en ;
                                                                       rdfs:label "IVDR"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ImplantableDevice
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ImplantableDevice> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> ;
                                                                                    owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#InVitroDiagnosticDevice> ,
                                                                                                     <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice> ;
                                                                                    rdfs:comment "medical device intended to be implanted in the human body"@en ;
                                                                                    rdfs:label "Implantable Device"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#InSituCorrection
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#InSituCorrection> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType> ;
                                                                                   owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Recall> ,
                                                                                                    <https://rmontesinosc.github.io/medical-devices-safety-ontology/#SafetyAlert> ,
                                                                                                    <https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice> ;
                                                                                   rdfs:comment "A corrective action performed directly on the affected device or system"@en ;
                                                                                   rdfs:label "In Situ Correction"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#InVitroDiagnosticDevice
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#InVitroDiagnosticDevice> rdf:type owl:Class ;
                                                                                          rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> ;
                                                                                          owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice> ;
                                                                                          rdfs:comment "A medical device used for in vitro diagnostic purposes"@en ;
                                                                                          rdfs:label "In Vitro Diagnostic Device"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident> rdf:type owl:Class ;
                                                                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://rmontesinosc.github.io/medical-devices-safety-ontology/#relatedRisk> ;
                                                                                             owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                             owl:onClass <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk>
                                                                                           ] ;
                                                                           rdfs:comment "A reported incident involving in a medical device"@en ;
                                                                           rdfs:label "Incident"@en ;
                                                                           rdfs:seeAlso "https://schema.org/MedicalEvent"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#IncidentType
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#IncidentType> rdf:type owl:Class ;
                                                                               rdfs:comment "A category describing the type of an incident"@en ;
                                                                               rdfs:label "Incident Type"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#MDR
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#MDR> rdf:type owl:Class ;
                                                                      rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#RegulatoryFramework> ;
                                                                      rdfs:comment "Medical Device Regulation."@en ;
                                                                      rdfs:label "MDR"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ManagedIncident
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ManagedIncident> rdf:type owl:Class ;
                                                                                  rdfs:comment "An incident that has an associated corrective action"@en ;
                                                                                  rdfs:label "Managed Incident"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer> rdf:type owl:Class ;
                                                                               rdfs:comment "An organization responsible for manufacturing a medical device"@en ;
                                                                               rdfs:label "Manufacturer"@en ;
                                                                               rdfs:seeAlso "http://xmlns.com/foaf/0.1/Organization"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> rdf:type owl:Class ;
                                                                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty <https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasManufacturer> ;
                                                                                                  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                  owl:onClass <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer>
                                                                                                ] ,
                                                                                                [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty <https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDeviceID> ;
                                                                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                  owl:onDataRange xsd:string
                                                                                                ] ;
                                                                                rdfs:comment "A medical device represented in the ontology"@en ;
                                                                                rdfs:label "Medical Device"@en ;
                                                                                rdfs:seeAlso "https://schema.org/MedicalDevice"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#Open
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#Open> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAStatus> ;
                                                                       rdfs:comment "Status indicating that a field safety corrective action is open."@en ;
                                                                       rdfs:label "Open"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#OpenCorrectiveAction
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#OpenCorrectiveAction> rdf:type owl:Class ;
                                                                                       rdfs:comment "A corrective action whose status is open"@en ;
                                                                                       rdfs:label "Open Corrective Action"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ProbabilityLevel
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ProbabilityLevel> rdf:type owl:Class ;
                                                                                   rdfs:comment "A probability level associated with a risk"@en ;
                                                                                   rdfs:label "Probability Level"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#Recall
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#Recall> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType> ;
                                                                         owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#SafetyAlert> ,
                                                                                          <https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice> ;
                                                                         rdfs:comment "A corrective action involving the recall of affected products"@en ;
                                                                         rdfs:label "Recall"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#RegulatoryFramework
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#RegulatoryFramework> rdf:type owl:Class ;
                                                                                      rdfs:comment "A European regulatory framework applicable to a medical device"@en ;
                                                                                      rdfs:label "Regulatory Framework"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice> rdf:type owl:Class ;
                                                                                 rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> ;
                                                                                 rdfs:comment "A medical device intended for repeated use"@en ;
                                                                                 rdfs:label "Reusable Device"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk> rdf:type owl:Class ;
                                                                       rdfs:comment "A risk associated with a medical device"@en ;
                                                                       rdfs:label "Risk"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskCategory
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskCategory> rdf:type owl:Class ;
                                                                               rdfs:comment "A conceptual category used to classify risks"@en ;
                                                                               rdfs:label "Risk Category"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass> rdf:type owl:Class ;
                                                                            rdfs:comment "A regulatory risk class assigned to a medical device"@en ;
                                                                            rdfs:label "Risk Class"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskType
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskType> rdf:type owl:Class ;
                                                                           rdfs:comment "A conceptual type used to classify risks"@en ;
                                                                           rdfs:label "Risk Type"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#SafetyAlert
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#SafetyAlert> rdf:type owl:Class ;
                                                                              rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType> ;
                                                                              owl:disjointWith <https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice> ;
                                                                              rdfs:comment "A corrective action consisting of a safety alert"@en ;
                                                                              rdfs:label "Safety Alert"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#Severity
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#Severity> rdf:type owl:Class ;
                                                                           rdfs:comment "A severity level associated with a risk"@en ;
                                                                           rdfs:label "Severity"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType> ;
                                                                             rdfs:comment "A corrective action consisting of a notice or communication to users"@en ;
                                                                             rdfs:label "User Notice"@en .


