#################################################################

###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#affectsDeviceType
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#affectsDeviceType> rdf:type owl:ObjectProperty ;
                                                                                    rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk> ;
                                                                                    rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#DeviceType> ;
                                                                                    rdfs:comment "Relates a risk to the type of medical device that may be affected by it."@en ;
                                                                                    rdfs:label "affects device type"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCorrectiveAction
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCorrectiveAction> rdf:type owl:ObjectProperty ;
                                                                                      rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident> ;
                                                                                      rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction> ;
                                                                                      rdfs:comment "Links an incident to the corrective action taken in response"@en ;
                                                                                      rdfs:label "has corrective action"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasFSCAStatus
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasFSCAStatus> rdf:type owl:ObjectProperty ;
                                                                                rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction> ;
                                                                                rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAStatus> ;
                                                                                rdfs:comment "Links a corrective action to its FSCA status"@en ;
                                                                                rdfs:label "has FSCA status"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasFSCAType
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasFSCAType> rdf:type owl:ObjectProperty ;
                                                                              rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction> ;
                                                                              rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType> ;
                                                                              rdfs:comment "Links a corrective action to its FSCA type"@en ;
                                                                              rdfs:label "has FSCA type"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasIncident
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasIncident> rdf:type owl:ObjectProperty ;
                                                                              rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> ;
                                                                              rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident> ;
                                                                              rdfs:comment "Links a medical device to an incident associated with it"@en ;
                                                                              rdfs:label "has incident"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasManufacturer
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasManufacturer> rdf:type owl:ObjectProperty ;
                                                                                  rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> ;
                                                                                  rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer> ;
                                                                                  rdfs:comment "Links a medical device to its manufacturer"@en ;
                                                                                  rdfs:label "has manufacturer"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasRiskClass
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasRiskClass> rdf:type owl:ObjectProperty ;
                                                                               rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> ;
                                                                               rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass> ;
                                                                               rdfs:comment "Links a medical device to its regulatory risk class"@en ;
                                                                               rdfs:label "has risk class"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#relatedRisk
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#relatedRisk> rdf:type owl:ObjectProperty ;
                                                                              rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident> ;
                                                                              rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk> ;
                                                                              rdfs:comment "Links an incident to a risk"@en ;
                                                                              rdfs:label "related risk"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#reportedBy
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#reportedBy> rdf:type owl:ObjectProperty ;
                                                                             rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident> ;
                                                                             rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer> ;
                                                                             rdfs:comment "Links an incident to the reporting manufacturer"@en ;
                                                                             rdfs:label "reported by"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#subjectToCorrectiveAction
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#subjectToCorrectiveAction> rdf:type owl:ObjectProperty ;
                                                                                            rdfs:domain <https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice> ;
                                                                                            rdfs:range <https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction> ;
                                                                                            rdfs:comment "Relates a medical device to a corrective action that applies to it."@en ;
                                                                                            rdfs:label "subject to corrective action"@en .


###  https://rmontesinosc.github.io/medical-devices-safety-ontology/#underRegulatoryFramework
<https://rmontesinosc.github.io/medical-devices-safety-ontology/#underRegulatoryFramework> rdf:type owl:ObjectProperty ;
