    <!-- http://example.org/medical-devices-ontology#hasScope -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasScope">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
