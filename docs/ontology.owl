        <rdfs:comment xml:lang="en">Indicates whether the device is active</rdfs:comment>
        <rdfs:label xml:lang="en">is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#isIVD -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#isIVD">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
