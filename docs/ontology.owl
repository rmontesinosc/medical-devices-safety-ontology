        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the textual value of the device type</rdfs:comment>
        <rdfs:label xml:lang="en">has device type text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDevicesAffected -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDevicesAffected">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">Stores the number of devices affected by a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">has devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasEUDAMEDFSCARef -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasEUDAMEDFSCARef">
