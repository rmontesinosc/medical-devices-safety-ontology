<?xml version="1.0"?>
<rdf:RDF xmlns="https://rmontesinosc.github.io/medical-devices-safety-ontology/"
     xml:base="https://rmontesinosc.github.io/medical-devices-safety-ontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:medical-devices-safety-ontology="https://rmontesinosc.github.io/medical-devices-safety-ontology/#">
    <owl:Ontology rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/">
        <owl:versionIRI rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/1.0/"/>
        <terms:creator>Rafael Montesinos Cano</terms:creator>
        <terms:description xml:lang="en">An ontology for modelling medical devices, safety incidents, risk classifications, manufacturers, regulatory frameworks and corrective actions in the medical device domain.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</terms:modified>
        <terms:provenance xml:lang="en">The ontology was developed as part of an academic practice on ontology engineering, documentation and publication using Protégé, WIDOCO, OOPS!, FOOPS! and GitHub Pages.</terms:provenance>
        <terms:title xml:lang="en">Medical Devices Safety Ontology</terms:title>
        <vann:preferredNamespacePrefix>mdso</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://rmontesinosc.github.io/medical-devices-safety-ontology#</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">Ontology for representing medical devices, incidents, risks, manufacturers, regulatory frameworks and corrective actions.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Devices Safety Ontology</rdfs:label>
        <owl:versionInfo>1.0</owl:versionInfo>
        <prov:generatedAtTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-04-27T00:00:00Z</prov:generatedAtTime>
        <prov:wasAttributedTo rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology#RafaelMontesinosCano"/>
        <prov:wasGeneratedBy rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology#OntologyDevelopmentActivity"/>
    </owl:Ontology>
    


