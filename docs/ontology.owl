     -->


    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#affectsDeviceType -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#affectsDeviceType">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#DeviceType"/>
        <rdfs:comment xml:lang="en">Relates a risk to the type of medical device that may be affected by it.</rdfs:comment>
        <rdfs:label xml:lang="en">affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCorrectiveAction">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Links an incident to the corrective action taken in response</rdfs:comment>
        <rdfs:label xml:lang="en">has corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasFSCAStatus -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasFSCAStatus">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAStatus"/>
        <rdfs:comment xml:lang="en">Links a corrective action to its FSCA status</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasFSCAType -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasFSCAType">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType"/>
        <rdfs:comment xml:lang="en">Links a corrective action to its FSCA type</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasIncident -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasIncident">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident"/>
        <rdfs:comment xml:lang="en">Links a medical device to an incident associated with it</rdfs:comment>
        <rdfs:label xml:lang="en">has incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasManufacturer -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasManufacturer">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links a medical device to its manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasRiskClass -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasRiskClass">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass"/>
        <rdfs:comment xml:lang="en">Links a medical device to its regulatory risk class</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#relatedRisk -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#relatedRisk">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk"/>
        <rdfs:comment xml:lang="en">Links an incident to a risk</rdfs:comment>
        <rdfs:label xml:lang="en">related risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#reportedBy -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#reportedBy">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links an incident to the reporting manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#subjectToCorrectiveAction -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#subjectToCorrectiveAction">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Relates a medical device to a corrective action that applies to it.</rdfs:comment>
        <rdfs:label xml:lang="en">subject to corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#underRegulatoryFramework -->


    <owl:ObjectProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#underRegulatoryFramework">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <rdfs:range rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Links a medical device to the regulatory framework that applies to it</rdfs:comment>
        <rdfs:label xml:lang="en">under regulatory framework</rdfs:label>
    </owl:ObjectProperty>
    


