    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/medical-devices-ontology#ActiveDevice -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device that depends on a source of energy for its operation</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#CorrectiveAction -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#CorrectiveAction">
        <rdfs:comment xml:lang="en">An action taken in response to an incident</rdfs:comment>
        <rdfs:label xml:lang="en">Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#DeviceType -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#DeviceType">
        <rdfs:comment xml:lang="en">A category describing the type of a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Device Type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#FSCAStatus -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#FSCAStatus">
        <rdfs:comment xml:lang="en">The status of a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA Status</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#FSCAType -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#FSCAType">
        <rdfs:comment xml:lang="en">A type of field safety corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA Type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#HighRiskDevice -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#HighRiskDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device considered high risk according to regulatory classification</rdfs:comment>
        <rdfs:label xml:lang="en">High-Risk Device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#ImplantableDevice -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">medical device intended to be implanted in the human body</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#InSituCorrection -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://example.org/medical-devices-ontology#FSCAType"/>
        <rdfs:comment xml:lang="en">A corrective action performed directly on the affected device or system</rdfs:comment>
        <rdfs:label xml:lang="en">In Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device used for in vitro diagnostic purposes</rdfs:comment>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#Incident -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/medical-devices-ontology#relatedRisk"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/medical-devices-ontology#Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A reported incident involving in a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#IncidentType -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#IncidentType">
        <rdfs:comment xml:lang="en">A category describing the type of an incident</rdfs:comment>
        <rdfs:label xml:lang="en">Incident Type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#ManagedIncident -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#ManagedIncident">
        <rdfs:comment xml:lang="en">An incident that has an associated corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">Managed Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#Manufacturer -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#Manufacturer">
        <rdfs:comment xml:lang="en">An organization responsible for manufacturing a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
        <rdfs:seeAlso xml:lang="en">http://xmlns.com/foaf/0.1/Organization</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#MedicalDevice -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#MedicalDevice">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/medical-devices-ontology#hasManufacturer"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/medical-devices-ontology#hasDeviceID"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device represented in the ontology</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Device</rdfs:label>
        <rdfs:seeAlso xml:lang="en">https://schema.org/MedicalDevice</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#OpenCorrectiveAction -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#OpenCorrectiveAction">
        <rdfs:comment xml:lang="en">A corrective action whose status is open</rdfs:comment>
        <rdfs:label xml:lang="en">Open Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#ProbabilityLevel -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#ProbabilityLevel">
        <rdfs:comment xml:lang="en">A probability level associated with a risk</rdfs:comment>
        <rdfs:label xml:lang="en">Probability Level</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#Recall -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#Recall">
        <rdfs:subClassOf rdf:resource="http://example.org/medical-devices-ontology#FSCAType"/>
        <rdfs:comment xml:lang="en">A corrective action involving the recall of affected products</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#RegulatoryFramework -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#RegulatoryFramework">
        <rdfs:comment xml:lang="en">A European regulatory framework applicable to a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#ReusableDevice -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#ReusableDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device intended for repeated use</rdfs:comment>
        <rdfs:label xml:lang="en">Reusable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#Risk -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#Risk">
        <rdfs:comment xml:lang="en">A risk associated with a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#RiskCategory -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#RiskCategory">
        <rdfs:comment xml:lang="en">A conceptual category used to classify risks</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#RiskClass -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#RiskClass">
        <rdfs:comment xml:lang="en">A regulatory risk class assigned to a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#RiskType -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#RiskType">
        <rdfs:comment xml:lang="en">A conceptual type used to classify risks</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#SafetyAlert -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://example.org/medical-devices-ontology#FSCAType"/>
        <rdfs:comment xml:lang="en">A corrective action consisting of a safety alert</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#Severity -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#Severity">
        <rdfs:comment xml:lang="en">A severity level associated with a risk</rdfs:comment>
        <rdfs:label xml:lang="en">Severity</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/medical-devices-ontology#UserNotice -->


    <owl:Class rdf:about="http://example.org/medical-devices-ontology#UserNotice">
        <rdfs:subClassOf rdf:resource="http://example.org/medical-devices-ontology#FSCAType"/>
        <rdfs:comment xml:lang="en">A corrective action consisting of a notice or communication to users</rdfs:comment>
        <rdfs:label xml:lang="en">User Notice</rdfs:label>
    </owl:Class>
    


