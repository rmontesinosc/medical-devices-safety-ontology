        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the contact email of a manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCountriesAffected -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCountriesAffected">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the countries affected by a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">has countries affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCountry -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCountry">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the country where a manufacturer is located</rdfs:comment>
        <rdfs:label xml:lang="en">has country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCountryReported -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCountryReported">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the country where the incident was reported</rdfs:comment>
        <rdfs:label xml:lang="en">has country reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDetectionDate -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDetectionDate">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the date on which an incident was detected.</rdfs:comment>
        <rdfs:label xml:lang="en">has detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDeviceID -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDeviceID">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the identifier of a manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has device ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDeviceName -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDeviceName">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the commercial name of a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">has device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDeviceTypeText -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDeviceTypeText">
