<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/medical-devices-ontology#"
     xml:base="http://example.org/medical-devices-ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:medical-devices-ontology="http://example.org/medical-devices-ontology#">
    <owl:Ontology rdf:about="http://example.org/medical-devices-ontology">
        <terms:creator>Rafael Montesinos Cano</terms:creator>
        <terms:description xml:lang="en">An ontology for modelling medical devices, safety incidents, risk classifications, manufacturers, regulatory frameworks and corrective actions in the medical device domain.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">Medical Devices Safety Ontology</terms:title>
        <rdfs:comment xml:lang="en">Ontology for representing medical devices, incidents, risks, manufacturers, regulatory frameworks and corrective actions.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Devices Safety Ontology</rdfs:label>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/medical-devices-ontology#affectsDeviceType -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#affectsDeviceType">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Risk"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#DeviceType"/>
        <rdfs:label xml:lang="en">Links a risk to a type of device affected by it</rdfs:label>
        <rdfs:label xml:lang="en">affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#hasCorrectiveAction">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Links an incident to the corrective action taken in response</rdfs:comment>
        <rdfs:label xml:lang="en">has corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasFSCAStatus -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#hasFSCAStatus">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#FSCAStatus"/>
        <rdfs:comment xml:lang="en">Links a corrective action to its FSCA status</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasFSCAType -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#hasFSCAType">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#FSCAType"/>
        <rdfs:comment xml:lang="en">Links a corrective action to its FSCA type</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasIncident -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#hasIncident">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:comment xml:lang="en">Links a medical device to an incident associated with it</rdfs:comment>
        <rdfs:label xml:lang="en">has incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#hasManufacturer">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links a medical device to its manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#hasRiskClass">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#RiskClass"/>
        <rdfs:comment xml:lang="en">Links a medical device to its regulatory risk class</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#relatedRisk -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#relatedRisk">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#Risk"/>
        <rdfs:comment xml:lang="en">Links an incident to a risk</rdfs:comment>
        <rdfs:label xml:lang="en">related risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#reportedBy -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#reportedBy">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links an incident to the reporting manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#subjectToCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#subjectToCorrectiveAction">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:label xml:lang="en">Links a medical device to a corrective action associated through an incident</rdfs:label>
        <rdfs:label xml:lang="en">subject to corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/medical-devices-ontology#underRegulatoryFramework -->


    <owl:ObjectProperty rdf:about="http://example.org/medical-devices-ontology#underRegulatoryFramework">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://example.org/medical-devices-ontology#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Links a medical device to the regulatory framework that applies to it</rdfs:comment>
        <rdfs:label xml:lang="en">under regulatory framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/medical-devices-ontology#correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#correctiveActionTaken">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether a corrective action was taken for the incident</rdfs:comment>
        <rdfs:label xml:lang="en">corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasActionDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasActionDate">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the date on which a corrective action started</rdfs:comment>
        <rdfs:label xml:lang="en">has action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasAffectedDeviceTypeText -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasAffectedDeviceTypeText">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the textual value of the affected device type</rdfs:comment>
        <rdfs:label xml:lang="en">has affected device type text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasAuthorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasAuthorizationNumber">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the regulatory authorization number of a manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasClosureDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasClosureDate">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the date on which a corrective action was closed</rdfs:comment>
        <rdfs:label xml:lang="en">has closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasCompetentAuthority -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasCompetentAuthority">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the competent authority associated with a manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has competent authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasContactEmail -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasContactEmail">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the contact email of a manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasCountriesAffected -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasCountriesAffected">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the countries affected by a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">has countries affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasCountry -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasCountry">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the country where a manufacturer is located</rdfs:comment>
        <rdfs:label xml:lang="en">has country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasCountryReported -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasCountryReported">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the country where the incident was reported</rdfs:comment>
        <rdfs:label xml:lang="en">has country reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasDetectionDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasDetectionDate">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the date on which an incident was detected.</rdfs:comment>
        <rdfs:label xml:lang="en">has detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasDeviceID -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasDeviceID">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the identifier of a manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has device ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasDeviceName -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasDeviceName">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the commercial name of a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">has device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasDeviceTypeText -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasDeviceTypeText">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the textual value of the device type</rdfs:comment>
        <rdfs:label xml:lang="en">has device type text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasDevicesAffected -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasDevicesAffected">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">Stores the number of devices affected by a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">has devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasEUDAMEDFSCARef -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasEUDAMEDFSCARef">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the EUDAMED reference of a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasEUDAMEDIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasEUDAMEDIncidentRef">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the EUDAMED reference of an incident</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasEUDAMEDSRN -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasEUDAMEDSRN">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the EUDAMED SRN of a manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasEventDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasEventDate">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the date on which the incident event occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">has event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasFSCADescription -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasFSCADescription">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the description of a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasFSCAID -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasFSCAID">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the identifier of a field safety corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasIMDRFCode -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasIMDRFCode">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the IMDRF code assigned to a risk</rdfs:comment>
        <rdfs:label xml:lang="en">has IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasIncidentDescription -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasIncidentDescription">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the description of an incident</rdfs:comment>
        <rdfs:label xml:lang="en">has incident description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasIncidentID -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasIncidentID">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the identifier of an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">has incident ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasIncidentTypeText -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasIncidentTypeText">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the textual value of the incident type</rdfs:comment>
        <rdfs:label>has incident type text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasIntendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasIntendedPurpose">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the intended purpose of a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">has intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasManufacturerID -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasManufacturerID">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the identifier of a manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasManufacturerName -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasManufacturerName">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the name of a manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasOutcome -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasOutcome">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">Stores the outcome of an incident</rdfs:label>
        <rdfs:label xml:lang="en">has outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasPatientAge -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasPatientAge">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment xml:lang="en">Stores the age of the patient associated with an incident</rdfs:comment>
        <rdfs:label xml:lang="en">has patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasPatientSex -->


