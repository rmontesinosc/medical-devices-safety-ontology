    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#InVitroDiagnosticDevice"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice"/>
        <rdfs:comment xml:lang="en">medical device intended to be implanted in the human body</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#InSituCorrection -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#InSituCorrection">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Recall"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#SafetyAlert"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice"/>
        <rdfs:comment xml:lang="en">A corrective action performed directly on the affected device or system</rdfs:comment>
        <rdfs:label xml:lang="en">In Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice"/>
        <rdfs:comment xml:lang="en">A medical device used for in vitro diagnostic purposes</rdfs:comment>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#relatedRisk"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A reported incident involving in a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
        <rdfs:seeAlso xml:lang="en">https://schema.org/MedicalEvent</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#IncidentType -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#IncidentType">
        <rdfs:comment xml:lang="en">A category describing the type of an incident</rdfs:comment>
        <rdfs:label xml:lang="en">Incident Type</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#MDR -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MDR">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Medical Device Regulation.</rdfs:comment>
        <rdfs:label xml:lang="en">MDR</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#ManagedIncident -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#ManagedIncident">
        <rdfs:comment xml:lang="en">An incident that has an associated corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">Managed Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer">
        <rdfs:comment xml:lang="en">An organization responsible for manufacturing a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
        <rdfs:seeAlso xml:lang="en">http://xmlns.com/foaf/0.1/Organization</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasManufacturer"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasDeviceID"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device represented in the ontology</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Device</rdfs:label>
        <rdfs:seeAlso xml:lang="en">https://schema.org/MedicalDevice</rdfs:seeAlso>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#Open -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Open">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAStatus"/>
        <rdfs:comment xml:lang="en">Status indicating that a field safety corrective action is open.</rdfs:comment>
        <rdfs:label xml:lang="en">Open</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#OpenCorrectiveAction -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#OpenCorrectiveAction">
        <rdfs:comment xml:lang="en">A corrective action whose status is open</rdfs:comment>
        <rdfs:label xml:lang="en">Open Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#ProbabilityLevel -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#ProbabilityLevel">
        <rdfs:comment xml:lang="en">A probability level associated with a risk</rdfs:comment>
        <rdfs:label xml:lang="en">Probability Level</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#Recall -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Recall">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#SafetyAlert"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice"/>
        <rdfs:comment xml:lang="en">A corrective action involving the recall of affected products</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#RegulatoryFramework -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#RegulatoryFramework">
        <rdfs:comment xml:lang="en">A European regulatory framework applicable to a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device intended for repeated use</rdfs:comment>
        <rdfs:label xml:lang="en">Reusable Device</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk">
        <rdfs:comment xml:lang="en">A risk associated with a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskCategory -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskCategory">
        <rdfs:comment xml:lang="en">A conceptual category used to classify risks</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskClass">
        <rdfs:comment xml:lang="en">A regulatory risk class assigned to a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskType -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#RiskType">
        <rdfs:comment xml:lang="en">A conceptual type used to classify risks</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Type</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#SafetyAlert -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#SafetyAlert">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice"/>
        <rdfs:comment xml:lang="en">A corrective action consisting of a safety alert</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#Severity -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Severity">
        <rdfs:comment xml:lang="en">A severity level associated with a risk</rdfs:comment>
        <rdfs:label xml:lang="en">Severity</rdfs:label>
    </owl:Class>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#UserNotice">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#FSCAType"/>
        <rdfs:comment xml:lang="en">A corrective action consisting of a notice or communication to users</rdfs:comment>
        <rdfs:label xml:lang="en">User Notice</rdfs:label>
    </owl:Class>
    


