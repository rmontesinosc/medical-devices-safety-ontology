        <rdfs:comment xml:lang="en">Stores the description of a risk</rdfs:comment>
        <rdfs:label xml:lang="en">has risk description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasRiskID -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasRiskID">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the identifier of a risk</rdfs:comment>
        <rdfs:label xml:lang="en">has risk ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/medical-devices-ontology#hasRiskName -->


    <owl:DatatypeProperty rdf:about="http://example.org/medical-devices-ontology#hasRiskName">
        <rdfs:domain rdf:resource="http://example.org/medical-devices-ontology#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
