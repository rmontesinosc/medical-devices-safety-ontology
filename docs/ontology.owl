    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#correctiveActionTaken">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether a corrective action was taken for the incident</rdfs:comment>
        <rdfs:label xml:lang="en">corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasActionDate -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasActionDate">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the date on which a corrective action started</rdfs:comment>
        <rdfs:label xml:lang="en">has action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasAffectedDeviceTypeText -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasAffectedDeviceTypeText">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the textual value of the affected device type</rdfs:comment>
        <rdfs:label xml:lang="en">has affected device type text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasAuthorizationNumber -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasAuthorizationNumber">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the regulatory authorization number of a manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasClosureDate -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasClosureDate">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the date on which a corrective action was closed</rdfs:comment>
        <rdfs:label xml:lang="en">has closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCompetentAuthority -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasCompetentAuthority">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the competent authority associated with a manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has competent authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasContactEmail -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasContactEmail">
