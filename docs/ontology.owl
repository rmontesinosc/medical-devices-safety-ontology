        <rdfs:label xml:lang="en">has EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasEUDAMEDSRN -->


