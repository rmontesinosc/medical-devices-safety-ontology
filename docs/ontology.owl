        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the EUDAMED SRN of a manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasEventDate -->


    <owl:DatatypeProperty rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasEventDate">
        <rdfs:domain rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the date on which the incident event occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">has event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#hasFSCADescription -->


