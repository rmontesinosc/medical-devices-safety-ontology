    <!-- https://rmontesinosc.github.io/medical-devices-safety-ontology/#ActiveDevice -->


    <owl:Class rdf:about="https://rmontesinosc.github.io/medical-devices-safety-ontology/#ActiveDevice">
        <rdfs:subClassOf rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#MedicalDevice"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#HighRiskDevice"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#ImplantableDevice"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#InVitroDiagnosticDevice"/>
        <owl:disjointWith rdf:resource="https://rmontesinosc.github.io/medical-devices-safety-ontology/#ReusableDevice"/>
        <rdfs:comment xml:lang="en">A medical device that depends on a source of energy for its operation</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


